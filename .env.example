# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# P0F-4: Resend 재인증 알림 메일
# - RESEND_API_KEY: https://resend.com/api-keys
# - RESEND_FROM: 도메인 미구매 단계는 onboarding@resend.dev 사용
#   운영 도메인 구매 후 'Cloud with you <noreply@yourdomain.com>' 으로 변경
RESEND_API_KEY=
RESEND_FROM=Cloud with you <onboarding@resend.dev>

# P0F-4: Vercel Cron 인증 secret (random 32+ chars)
# 생성 예: openssl rand -base64 32
CRON_SECRET=

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://legend-of-korea.vercel.app

# Payments
# 정식 출시 시 Live 키로 교체 (베타엔 테스트 키 그대로)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY=your_toss_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Food Image (Unsplash 자동 매칭)
UNSPLASH_ACCESS_KEY=

# Kakao Maps JavaScript SDK (lib/kakao-map.ts / components/shared/KakaoMap.tsx)
# - 발급: https://developers.kakao.com → 내 애플리케이션 → JavaScript 키
# - 도메인 등록 필수: https://legend-of-korea.vercel.app, http://localhost:3000
NEXT_PUBLIC_KAKAO_JS_KEY=

# 한국관광공사 TourAPI (lib/tour-api/** — 숙박 검색)
# - 발급: https://api.visitkorea.or.kr → 마이페이지 → 활용 신청
# - 절대 클라이언트 노출 금지 (NEXT_PUBLIC_ 접두사 X)
TOUR_API_KEY=

# 테스트 기간 접속 게이트 (middleware.ts)
# MAX_DAILY_VISITORS: 하루 허용 고유 IP 수 (기본 50)
# NEXT_PUBLIC_MAINTENANCE_MODE=true 로 설정 시 관리자 외 전원 차단
# 관리자 바이패스는 ADMIN_EMAILS (아래) 에 등록된 이메일로 로그인한 사용자만
MAX_DAILY_VISITORS=50
NEXT_PUBLIC_MAINTENANCE_MODE=false
ADMIN_EMAILS=

# 회원가입 페이지 테스트 기간 안내 배너 표시 (true 면 노출)
NEXT_PUBLIC_TEST_MODE=false

# Cloudflare Turnstile (signup / login 봇 방지)
# - 발급: https://dash.cloudflare.com → Turnstile (무료, 무제한)
# - 도메인 등록 필수: legend-of-korea.vercel.app, localhost
# - 미설정 시 dev 더미 키 (always-pass) 자동 사용 — 운영 배포 전 반드시 발급 키로 교체
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ZEP 통합 스페이스 비밀번호 (서버 전용 — 절대 NEXT_PUBLIC_ 접두사 금지)
# 활성 패스 보유자만 /api/zep/access 를 통해 발급 받는다.
# 운영자가 ZEP 콘솔에서 스페이스 비밀번호 설정 후 동일 값 입력.
ZEP_SPACE_PASSWORD=legendofkorea2026

# 성장 지도 시스템 버전 (PRD 2026-05 — 무관/문관 → K-콘텐츠 카테고리 해금)
# - 미설정 또는 임의 값 = v1 (기존 무관/문관 분기 시스템)
# - 'v2' = 신규 시스템 (10 레벨 K-콘텐츠 카테고리 + 사진 해금 + AvatarSelectModal)
# 운영 절차:
#  1. supabase/migrations/057_avatar_unlock_system.sql 적용
#  2. supabase/migrations/059_avatar_auto_mapping.sql 적용
#  3. NEXT_PUBLIC_AVATAR_SYSTEM=v2 설정 + 재배포
#  4. v2 검증 완료 후 cleanup commit + 058 (DROP) 적용
NEXT_PUBLIC_AVATAR_SYSTEM=

# 카트·결제 시스템 활성화 (P1-8). 베타 단계 'false' 로 유지.
# 'true' 로 토글 시 헤더 CartBadge + 우측 CartSidePanel 즉시 복원.
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# 테스트 기간 전체 패스 개방 (서버 전용 — 클라이언트 노출 금지)
# true 면 /api/passes/status 가 모든 사용자에게 풀 액세스 반환.
# 실제 결제·구독 로직은 그대로이며, 이 플래그만 false 로 돌리면 즉시 복원됨.
TEST_MODE=false

# AI Curation (배포 전까지 false 유지)
# 활성화 절차:
# 1. AI_CURATION_ENABLED=true 로 변경
# 2. ANTHROPIC_API_KEY 또는 OPENAI_API_KEY 중 하나 설정
# 3. (선택) AI_MODEL 지정 — 미설정 시 기본값 사용
#    Anthropic 기본: claude-haiku-4-5-20251001
#    OpenAI 기본: gpt-4o-mini
# 4. pnpm add @anthropic-ai/sdk 또는 pnpm add openai
# 5. lib/ai/providers/{anthropic,openai}.ts 의 STUB 주석 해제
AI_CURATION_ENABLED=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=
