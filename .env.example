# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# P0F-4: Resend 재인증 알림 메일
# - RESEND_API_KEY: https://resend.com/api-keys
# - RESEND_FROM: 도메인 미구매 단계는 onboarding@resend.dev 사용
#   운영 도메인 구매 후 'Cloud with you <noreply@yourdomain.com>' 으로 변경
RESEND_API_KEY=
RESEND_FROM=Cloud with you <onboarding@resend.dev>

# P0F-4: Vercel Cron 인증 secret (random 32+ chars)
# 생성 예: openssl rand -base64 32
CRON_SECRET=

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://legend-of-korea.vercel.app

# Payments
NEXT_PUBLIC_TOSS_CLIENT_KEY=your_toss_client_key
TOSS_SECRET_KEY=your_toss_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Food Image (Unsplash 자동 매칭)
UNSPLASH_ACCESS_KEY=

# 테스트 기간 접속 게이트 (middleware.ts)
# MAX_DAILY_VISITORS: 하루 허용 고유 IP 수 (기본 50)
# NEXT_PUBLIC_MAINTENANCE_MODE=true 로 설정 시 관리자 외 전원 차단
# 관리자 바이패스는 ADMIN_EMAILS (아래) 에 등록된 이메일로 로그인한 사용자만
MAX_DAILY_VISITORS=50
NEXT_PUBLIC_MAINTENANCE_MODE=false
ADMIN_EMAILS=

# 회원가입 페이지 테스트 기간 안내 배너 표시 (true 면 노출)
NEXT_PUBLIC_TEST_MODE=false

# 카트·결제 시스템 활성화 (P1-8). 베타 단계 'false' 로 유지.
# 'true' 로 토글 시 헤더 CartBadge + 우측 CartSidePanel 즉시 복원.
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# 테스트 기간 전체 패스 개방 (서버 전용 — 클라이언트 노출 금지)
# true 면 /api/passes/status 가 모든 사용자에게 풀 액세스 반환.
# 실제 결제·구독 로직은 그대로이며, 이 플래그만 false 로 돌리면 즉시 복원됨.
TEST_MODE=false

# AI Curation (배포 전까지 false 유지)
# 활성화 절차:
# 1. AI_CURATION_ENABLED=true 로 변경
# 2. ANTHROPIC_API_KEY 또는 OPENAI_API_KEY 중 하나 설정
# 3. (선택) AI_MODEL 지정 — 미설정 시 기본값 사용
#    Anthropic 기본: claude-haiku-4-5-20251001
#    OpenAI 기본: gpt-4o-mini
# 4. pnpm add @anthropic-ai/sdk 또는 pnpm add openai
# 5. lib/ai/providers/{anthropic,openai}.ts 의 STUB 주석 해제
AI_CURATION_ENABLED=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=
